# 复制为 quiz-live-relay.env（已被 git ignore，勿提交）
#
# WebSocket 中继部署目标：东京 Lighthouse /opt/quiz-live
# 前提：服务器已跑过一次 deploy/quiz-live-server-setup.sh（Node + pm2）

# 公网 IP 或域名
RELAY_HOST=your-server-ip

# SSH 登录用户（Lighthouse 默认常为 ubuntu 或 root）
RELAY_USER=ubuntu

# 远端目录（与 quiz-live-server-setup.sh 一致）
RELAY_APP_DIR=/opt/quiz-live

# pm2 进程名
RELAY_PM2_NAME=quiz-relay

# 可选：SSH 私钥路径；留空则用系统默认（~/.ssh/id_rsa 等）
# RELAY_SSH_KEY=C:\Users\you\.ssh\id_ed25519

# 可选：SSH 端口，默认 22
# RELAY_SSH_PORT=22
